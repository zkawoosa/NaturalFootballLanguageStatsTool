# nfl-query environment variables

# Runtime source selection
NFL_SOURCE=nflverse

# Which season the app should assume when a query omits season
NFLVERSE_DEFAULT_SEASON=2025

# Which season to materialize into SQLite when running `npm run build:snapshot`
NFLVERSE_SNAPSHOT_SEASON=2025

# Logging controls
NFL_LOG_TO_FILE=0
NFL_QUERY_TEST_QUIET_LOGS=0

# Cache policy
NFL_CACHE_ENABLED=1
NFL_CACHE_TTL_SECONDS=300

# Operator-only status access
NFL_STATUS_USERNAME=operator
NFL_STATUS_PASSWORD=change-me

# SQLite path for the snapshot, query history, and persisted cache
NFL_SQLITE_PATH=data/nfl-query.sqlite
